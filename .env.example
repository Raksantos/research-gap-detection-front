# Same-origin by default; requests go to /api/* and are proxied by Vite in dev or by nginx in prod.
# Override only to hit the backend directly (bypassing the proxy), e.g. http://127.0.0.1:8000
VITE_API_BASE_URL=
# Dev proxy target (Vite only). Match where Django runs (see ../research-gap-detection).
BACKEND_ORIGIN=http://127.0.0.1:8000
