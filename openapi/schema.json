    },
    "/api/gaps/run/": {
      "post": {
        "operationId": "gaps_run",
        "description": "Create a new GapDetectionJob bound to an existing successful MappingJob and enqueue the detection pipeline. Returns 202 with the job_id; clients should poll /api/gaps/jobs/{id}/.",
        "tags": ["Gaps"],
