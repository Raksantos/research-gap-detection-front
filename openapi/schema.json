  "components": {
    "schemas": {
      "CoOccurrenceEdge": {
        "type": "object",
        "properties": {
          "entity_a": {
            "$ref": "#/components/schemas/CoOccurrenceEndpoint"
          },
          "entity_b": {
            "$ref": "#/components/schemas/CoOccurrenceEndpoint"
          },
          "weight": {
            "type": "integer"
          }
        },
        "required": ["entity_a", "entity_b", "weight"]
      },
      "CoOccurrenceEndpoint": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["id", "name", "type"]
      },
      "CoOccurrencesResponse": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "edges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CoOccurrenceEdge"
            }
          }
        },
        "required": ["edges", "job_id", "total"]
      },
      "Document": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "abstract": {
            "type": "string",
            "nullable": true
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "year": {
            "type": "integer",
            "nullable": true
          },
          "doi": {
            "type": "string",
            "nullable": true
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["authors", "external_id", "keywords", "source", "title"]
      },
      "EntitiesResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "total": {
            "type": "integer"
          },
          "entities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entity"
            }
          }
        },
        "required": ["entities", "total"]
      },
      "Entity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "normalized_name": {
            "type": "string"
          },
          "document_count": {
            "type": "integer"
          }
        },
        "required": ["document_count", "id", "name", "normalized_name", "type"]
      },
      "EntityRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["id", "name", "type"]
      },
