    "/api/gaps/jobs/{job_id}/gaps/": {
      "get": {
        "operationId": "gaps_job_gaps",
        "description": "List the gaps produced by a job, ordered by descending rarity score, optionally filtered by gap type.",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string",
              "enum": [
                "future_work",
                "limitation",
                "rare_combination",
                "underexplored_topic"
              ]
            }
          }
        ],
        "tags": ["Gaps"],
