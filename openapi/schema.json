                "$ref": "#/components/schemas/RunGapDetectionRequest"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "jwtAuth": []
          },
          {}
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunGapDetectionResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
