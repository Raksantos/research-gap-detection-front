          {
            "in": "query",
            "name": "complexity_tier",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "cost_tier",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "gap_detection_job_id",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "tags": ["Feasibility"],
        "security": [
          {
            "jwtAuth": []
          },
          {}
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FeasibilityAssessment"
                  }
                }
              }
            },
            "description": ""
          }
        }
      }
    },
